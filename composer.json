{
    "name": "bkstar123/bkscms",
    "type": "project",
    "description": "A Laravel based generic content management system (CMS).",
    "keywords": [
        "framework",
        "laravel",
        "CMS",
        "Content management system"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Hoang Anh Tuan",
            "email": "hoangtuandhbk@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.8",
        "laravel/framework": "^12.0",
        "laravel/helpers": "^1.7",
        "laravel/tinker": "^2.9",
        "laravel/ui": "^4.6",
        "pusher/pusher-php-server": "^7.2",
        "typicms/nestablecollection": "^5.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "laravel/pail": "^1.2",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "phpunit/phpunit": "^11.5.3"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "platform": {
            "php": "8.4.8"
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Bkstar123\\BksCMS\\AdminPanel\\": "packages/bkscms-admin-panel/src/",
            "Bkstar123\\BksCMS\\Utilities\\": "packages/bkscms-utilities/src/",
            "Bkstar123\\Flashing\\": "packages/flashing/src/",
            "Bkstar123\\LaraTune\\": "packages/laratune/src/",
            "Bkstar123\\LaravelRecaptcha\\": "packages/laravel-recaptcha/src/",
            "Bkstar123\\LaravelUploader\\": "packages/laravel-uploader/src/",
            "Bkstar123\\LogEnhancer\\": "packages/log-enhancer/src/",
            "Bkstar123\\MySqlSearch\\": "packages/mysql-search/src/"
        },
        "classmap": [
            "packages/bkscms-admin-panel/src/database/seeds"
        ],
        "files": [
            "app/Functions/kstock_helpers.php",
            "packages/flashing/src/Helpers/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    }
}
